#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/proc/cygdrive/c/Windows/System32/dropship-ergo/node_modules/.pnpm/prisma@7.8.0_@types+react@1_deed85f8d56d25c25077185c3407959f/node_modules/prisma/node_modules:/proc/cygdrive/c/Windows/System32/dropship-ergo/node_modules/.pnpm/prisma@7.8.0_@types+react@1_deed85f8d56d25c25077185c3407959f/node_modules:/proc/cygdrive/c/WINDOWS/system32/dropship-ergo/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/proc/cygdrive/c/Windows/System32/dropship-ergo/node_modules/.pnpm/prisma@7.8.0_@types+react@1_deed85f8d56d25c25077185c3407959f/node_modules/prisma/node_modules:/proc/cygdrive/c/Windows/System32/dropship-ergo/node_modules/.pnpm/prisma@7.8.0_@types+react@1_deed85f8d56d25c25077185c3407959f/node_modules:/proc/cygdrive/c/WINDOWS/system32/dropship-ergo/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../../build/index.js" "$@"
else
  exec node  "$basedir/../../build/index.js" "$@"
fi
